<!DOCTYPE html>
<html lang="en">
  <head>
    <title>HMD Studio — Editorial Web Studio</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="HMD Studio — premium editorial web studio crafting bold digital identities for ambitious brands. Custom development, visual identity &amp; art direction.">
    <meta property="og:title" content="HMD Studio — Editorial Web Studio">
    <meta property="og:description" content="Premium editorial web studio crafting bold digital identities for ambitious brands. Custom development, visual identity &amp; art direction.">
    <meta property="og:type" content="website">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "HMD Studio",
      "description": "Editorial web studio creating bold digital identities for ambitious brands. Web development, visual identity and art direction.",
      "url": "https://hmdstudio.com",
      "email": "hello@hmdstudio.com",
      "serviceType": ["Web Development", "Visual Identity", "Web Design", "Art Direction"],
      "areaServed": "Worldwide",
      "knowsAbout": ["Editorial Design", "Web Development", "Visual Identity", "Brand Strategy"]
    }
    </script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="<%= controller_name %> <%= action_name %>" data-controller="cursor page-transition grain">
    <nav class="navbar" data-controller="navbar navbar-scroll">
      <div class="navbar__inner">
        <%= link_to root_path, class: "navbar__logo" do %>
          <span class="navbar__logo-name">HMD STUDIO</span>
          <span class="navbar__logo-sub">Editorial Web Studio</span>
        <% end %>

        <div class="navbar__links">
          <%= link_to "01—WORK",    work_path,    class: "navbar__link #{'navbar__link--active' if controller_name == 'pages' && action_name == 'work'}",    data: { controller: "magnetic" } %>
          <%= link_to "02—ABOUT",   about_path,   class: "navbar__link #{'navbar__link--active' if controller_name == 'pages' && action_name == 'about'}",   data: { controller: "magnetic" } %>
          <%= link_to "03—CONTACT", contact_path, class: "navbar__link #{'navbar__link--active' if controller_name == 'pages' && action_name == 'contact'}", data: { controller: "magnetic" } %>
        </div>

        <button class="navbar__burger" data-navbar-target="burger" data-action="click->navbar#toggle" aria-label="Menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <div class="navbar__overlay" data-navbar-target="overlay" data-action="click->navbar#toggle">
        <div class="navbar__overlay-links">
          <%= link_to "01—WORK",    work_path,    class: "navbar__overlay-link", data: { action: "click->navbar#toggle" } %>
          <%= link_to "02—ABOUT",   about_path,   class: "navbar__overlay-link", data: { action: "click->navbar#toggle" } %>
          <%= link_to "03—CONTACT", contact_path, class: "navbar__overlay-link", data: { action: "click->navbar#toggle" } %>
        </div>
      </div>
    </nav>

    <main class="main <%= 'main--fullbleed' if controller_name == 'pages' && action_name == 'home' %>">
      <%= yield %>
      <%= render 'shared/footer' %>
    </main>

    <div id="hmd-transition">
      <span id="hmd-transition-label">HMD</span>
    </div>

    <div id="hmd-cursor">
      <div id="hmd-cursor-dot"></div>
      <div id="hmd-cursor-ring"></div>
    </div>
  </body>
</html>

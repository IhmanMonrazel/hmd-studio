<%# ── Diagnostic: s2 spacing + all-section background audit ── %>
<script type="module">
  document.addEventListener("turbo:load", () => {
    // S2 — detailed spacing audit for s2 and its direct children
    const s2 = document.querySelector(".s2")
    if (s2) {
      const cs = getComputedStyle(s2)
      console.group("[home-scroll] s2 spacing audit")
      console.log("s2:", {
        height:    cs.height,
        minHeight: cs.minHeight,
        padTop:    cs.paddingTop,
        padBot:    cs.paddingBottom,
        bg:        cs.backgroundColor,
      })
      Array.from(s2.children).forEach(child => {
        const cc = getComputedStyle(child)
        console.log(`  .${child.className.split(" ")[0]}:`, {
          height:    cc.height,
          minHeight: cc.minHeight,
          padTop:    cc.paddingTop,
          padBot:    cc.paddingBottom,
          marginTop: cc.marginTop,
          marginBot: cc.marginBottom,
        })
      })
      console.groupEnd()
    }

    // All sections — background audit (no rgb(255,255,255) expected)
    const targets = [
      { id: "main--fullbleed", el: document.querySelector(".main--fullbleed") },
      { id: "s1-s2-sequence",  el: document.querySelector(".s1-s2-sequence") },
      { id: "S1", el: document.querySelector(".s1") },
      { id: "S2", el: document.querySelector(".s2") },
      { id: "S3", el: document.querySelector(".s3") },
      { id: "S4", el: document.querySelector(".s4") },
      { id: "S5", el: document.querySelector(".s5") },
      { id: "S6", el: document.querySelector(".s6") },
    ]
    console.group("[home-scroll] background audit")
    targets.forEach(({ id, el }) => {
      if (!el) return
      const bg = getComputedStyle(el).backgroundColor
      const isWhite = bg === "rgb(255, 255, 255)"
      console[isWhite ? "warn" : "log"](`${id}: ${bg}${isWhite ? " ← UNEXPECTED WHITE" : ""}`)
    })
    console.groupEnd()
  })
</script>

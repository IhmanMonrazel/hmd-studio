<div data-controller="home-scroll">

  <%# ── S1 · Hero video ──────────────────────────────────── %>
  <section class="s1">
    <video
      class="s1__media"
      src="https://res.cloudinary.com/dtlybacjm/video/upload/v1774611756/HMD_studio_-_4_m21oym.mp4"
      autoplay
      loop
      muted
      playsinline
    ></video>
    <div class="s1__overlay"></div>
  </section>

  <%# ── S2 · Hook / Positioning ──────────────────────────── %>
  <section class="s2">
    <div class="s2__content">
      <h1 class="s2__title">HMD STUDIO</h1>
      <p class="s2__sub">Editorial web studio for brands that refuse to be forgettable.</p>
    </div>
    <div class="s2__sphere-mount" aria-hidden="true"></div>
  </section>

  <%# ── S3 · Services ─────────────────────────────────────── %>
  <section class="s3">
    <h2 class="visually-hidden">Our Services</h2>
    <div class="s3__item">
      <h3 class="s3__item-title">DIRECTION ARTISTIQUE</h3>
      <p class="s3__item-desc">Pour les marques qui veulent un regard, pas un template.</p>
    </div>
    <hr class="s3__rule" aria-hidden="true">
    <div class="s3__item">
      <h3 class="s3__item-title">DÉVELOPPEMENT WEB</h3>
      <p class="s3__item-desc">Sites sur-mesure. Pas de themes, pas de Webflow.</p>
    </div>
    <hr class="s3__rule" aria-hidden="true">
    <div class="s3__item">
      <h3 class="s3__item-title">IDENTITÉ VISUELLE</h3>
      <p class="s3__item-desc">Du logo au système complet. Cohérent sur tous les supports.</p>
    </div>
  </section>

  <%# ── S4 · Work teaser ──────────────────────────────────── %>
  <section class="s4">
    <h2 class="visually-hidden">Our Work</h2>
    <%= link_to work_path, class: "s4__link" do %>
      <img
        class="s4__image"
        src="https://res.cloudinary.com/dtlybacjm/image/upload/v1774458352/GFS_Didot_6_xlasdg.jpg"
        alt="Our Work — HMD Studio"
        loading="eager"
      >
      <div class="s4__overlay">
        <span class="s4__overlay-text">OUR WORK</span>
      </div>
    <% end %>
  </section>

  <%# ── S5 · Differentiator (red) ─────────────────────────── %>
  <section class="s5">
    <h2 class="visually-hidden">Why HMD Studio</h2>
    <div class="s5__grid">
      <div class="s5__block s5__block--1">
        <strong class="s5__block-title">Contact-based only.</strong>
        <p class="s5__block-desc">No pricing page. No packages. We qualify before we commit.</p>
      </div>
      <div class="s5__block s5__block--2">
        <strong class="s5__block-title">Editorial point of view.</strong>
        <p class="s5__block-desc">Every project starts with a creative direction, not a brief template.</p>
      </div>
      <div class="s5__block s5__block--3">
        <strong class="s5__block-title">Built to last.</strong>
        <p class="s5__block-desc">No shortcuts. No page builders. Code written to perform and endure.</p>
      </div>
    </div>
  </section>

  <%# ── S6 · CTA ───────────────────────────────────────────── %>
  <section class="s6">
    <div class="s6__top">
      <h2 class="s6__title">LET'S BUILD SOMETHING STRANGE</h2>
    </div>
    <hr class="s6__rule">
    <div class="s6__colophon">
      <p>HMD STUDIO &mdash; EDITORIAL WEB STUDIO</p>
      <p>hello@hmdstudio.com</p>
      <p>INSTAGRAM / LINKEDIN</p>
      <p>&copy; 2025 HMD STUDIO</p>
    </div>
  </section>

</div><%# /home-scroll %>

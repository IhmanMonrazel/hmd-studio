<div data-controller="home-scroll">
<section class="hero-video">
  <video
    class="hero-video__media"
    src="https://res.cloudinary.com/dtlybacjm/video/upload/v1774611756/HMD_studio_-_4_m21oym.mp4"
    autoplay
    loop
    muted
    playsinline
  ></video>
  <div class="hero-video__overlay"></div>
</section>

<section class="s2">
  <div class="s2__col s2__col--left">
    <h2 class="s2__title">
      WE CREATE<br>
      BOLD DIGITAL<br>
      IDENTITIES
    </h2>
  </div>
  <div class="s2__col s2__col--right">
    <div class="s2__image-wrap">
      <img
        class="s2__image"
        src="https://res.cloudinary.com/dtlybacjm/image/upload/v1774633423/GFS_Didot_9_gpsfaj.png"
        alt="HMD Studio — Bold Digital Identities"
        loading="eager"
      >
    </div>
  </div>
</section>

<section class="s3">
  <div class="s3__header">
    <h2 class="s6__title">IDENTITY</h2>
  </div>
  <div class="s3__grid">
    <div class="s3__cell">
      <img src="https://res.cloudinary.com/dtlybacjm/image/upload/v1774455089/2907EDCA-BB45-4125-9FAF-22D7C07FAA9C_pyqauu.jpg" alt="Identity 1" loading="eager">
    </div>
    <div class="s3__cell">
      <img src="https://res.cloudinary.com/dtlybacjm/image/upload/v1774446193/760F2287-F454-4DDA-8E88-64AFF80C75EB_zk9fnd.png" alt="Identity 2" loading="eager">
    </div>
    <div class="s3__cell">
      <img src="https://res.cloudinary.com/dtlybacjm/image/upload/v1774612999/GFS_Didot_7_szoeli.jpg" alt="Identity 3" loading="eager" style="object-fit: cover; width: 100%; height: 100%;">
    </div>
    <div class="s3__cell">
      <img src="https://res.cloudinary.com/dtlybacjm/image/upload/v1774446192/IMG_4992_urvtrh.jpg" alt="Identity 4" loading="eager">
    </div>
  </div>
</section>

<section class="s4">
  <div class="s4__header">
    <h2 class="s4__title">WHAT WE DO</h2>
  </div>
  <div class="s4__cols">
    <div class="s4__col">
      <h3 class="s4__col-title">Web Development</h3>
      <p class="s4__col-text">We build fast, scalable and reliable websites with clean and efficient code.</p>
    </div>
    <div class="s4__col">
      <h3 class="s4__col-title">Visual Identity</h3>
      <p class="s4__col-text">We craft strong and distinctive visual identities that make your brand instantly recognizable.</p>
    </div>
    <div class="s4__col">
      <h3 class="s4__col-title">Web Design</h3>
      <p class="s4__col-text">We design modern, bold and user-focused interfaces that elevate your online presence.</p>
    </div>
  </div>
</section>

<section class="s5">
  <%= link_to work_path, class: "s5__link" do %>
    <img
      class="s5__image"
      src="https://res.cloudinary.com/dtlybacjm/image/upload/v1774458352/GFS_Didot_6_xlasdg.jpg"
      alt="Our Work"
      loading="eager"
    >
  <% end %>
</section>

<section class="s6" data-controller="tribal3d" data-tribal3d-size-value="280" data-tribal3d-camera-z-value="6.5">
  <div class="s6__header">
    <h2 class="s6__title">WHY WORK WITH US</h2>
  </div>

  <div class="s6__blocks">
    <div class="s6__block s6__block--1">
      <h3 class="s6__block-title">WE DON'T DO BORING</h3>
      <p class="s6__block-text">We don't build generic websites. We create strong, distinctive digital identities.</p>
    </div>
    <div class="s6__block s6__block--2">
      <h3 class="s6__block-title">FAST. CLEAN. NO EXCUSES.</h3>
      <p class="s6__block-text">Fast, reliable and scalable builds with clean and efficient code.</p>
    </div>
    <div class="s6__block s6__block--3">
      <h3 class="s6__block-title">RESULTS, NOT VIBES.</h3>
      <p class="s6__block-text">Design and development focused on results. Not just aesthetics.</p>
    </div>
  </div>

</section>

<section class="s7">
  <div class="s7__top">
    <h2 class="s7__title">LET'S BUILD SOMETHING STRANGE</h2>
  </div>
  <hr class="s7__rule">
  <div class="s7__colophon">
    <p>HMD STUDIO &mdash; EDITORIAL WEB STUDIO</p>
    <p>hello@hmdstudio.com</p>
    <p>INSTAGRAM / LINKEDIN</p>
    <p>&copy; 2025 HMD STUDIO</p>
  </div>
</section>
</div><%# /home-scroll %>

<%# ─── HERO ─────────────────────────────────────────────── %>
<section class="bc-hero">
  <div class="bc-hero__inner">
    <p class="bc-hero__eyebrow">02 &mdash; Web Development</p>
    <h1 class="bc-hero__title">SAFEMOOV</h1>
    <p class="bc-hero__sub">Real-time security incident reporting app</p>
    <p class="bc-hero__stack">Ruby on Rails &nbsp;&middot;&nbsp; PostgreSQL &nbsp;&middot;&nbsp; Cloudinary &nbsp;&middot;&nbsp; Stimulus.js &nbsp;&middot;&nbsp; Flatpickr</p>
    <a class="bc-hero__cta"
       href="https://safemoov-b5748a98028e.herokuapp.com/"
       target="_blank"
       rel="noopener noreferrer">LIVE DEMO &rarr;</a>
  </div>
</section>

<%# ─── SHOWCASE GSAP ───────────────────────────────────── %>
<section class="sm-showcase" data-controller="safemoov-showcase">
  <div class="sm-card">

    <%# Image placeholder %>
    <div class="sm-card__img">
      <svg viewBox="0 0 48 36" fill="none" xmlns="http://www.w3.org/2000/svg" width="40" height="30">
        <rect width="48" height="36" rx="2" fill="#d1d5db"/>
        <circle cx="18" cy="14" r="4" fill="#9ca3af"/>
        <path d="M0 27l12-10 8 8 8-7 20 14H0z" fill="#9ca3af"/>
      </svg>
    </div>

    <%# Séparateur %>
    <div class="sm-card__sep"></div>

    <%# Badge + titre %>
    <div class="sm-card__header">
      <span class="sm-card__badge">ACCIDENT</span>
      <h2 class="sm-card__title" data-safemoov-showcase-target="title">
        Incendie en zone rurale
      </h2>
    </div>

    <%# Méta-données %>
    <ul class="sm-card__meta">
      <li data-safemoov-showcase-target="metaItem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
        Sector Santa Rosa, Provincia de Carchi
      </li>
      <li data-safemoov-showcase-target="metaItem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
          <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
        </svg>
        17/01/2025
      </li>
      <li data-safemoov-showcase-target="metaItem">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
          <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
        </svg>
        10:42
      </li>
    </ul>

    <%# Séparateur %>
    <div class="sm-card__sep"></div>

    <%# Description %>
    <div class="sm-card__desc" data-safemoov-showcase-target="description">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" style="flex-shrink:0;margin-top:2px">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <p>Un départ de feu a été observé en bordure de la route nationale. Les pompiers locaux ont été alertés. La zone est partiellement bloquée à la circulation.</p>
    </div>

    <%# Séparateur %>
    <div class="sm-card__sep"></div>

    <%# Votes %>
    <div class="sm-card__votes" data-safemoov-showcase-target="votes">
      <button class="sm-card__vote-btn">&#128077; 4</button>
      <button class="sm-card__vote-btn">&#128078; 3</button>
    </div>
    <p class="sm-card__login-hint">Connectez-vous pour voter ou commenter</p>

  </div>
</section>

<%# ─── CTA FINAL ──────────────────────────────────────── %>

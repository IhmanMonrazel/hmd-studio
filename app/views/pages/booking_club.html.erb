            rx="2" fill="#2a3f5a"/>
      <rect x="80" y="330" width="400" height="3"
            rx="1" fill="#3a5470" opacity="0.8"/>
      <!-- Dock posts -->
      <rect x="100" y="348" width="6" height="40" fill="#243448"/>
      <rect x="200" y="348" width="6" height="40" fill="#243448"/>
      <rect x="300" y="348" width="6" height="40" fill="#243448"/>
      <rect x="400" y="348" width="6" height="40" fill="#243448"/>
      <rect x="460" y="348" width="6" height="35" fill="#243448"/>

      <!-- Boat 1 — Eight+ Competition (long racing shell) -->
      <g transform="translate(120, 316)">
        <path d="M0,8 Q60,-2 280,6 Q340,8 360,12 Q340,16 280,14 Q60,18 0,12 Z"
              fill="#2a4a7a" stroke="#4a7ab5" stroke-width="0.8"/>
        <!-- Seats -->
        <rect x="40" y="7" width="8" height="4" rx="1" fill="#3a5a8a" opacity="0.8"/>
        <rect x="70" y="7" width="8" height="4" rx="1" fill="#3a5a8a" opacity="0.8"/>
        <rect x="100" y="7" width="8" height="4" rx="1" fill="#3a5a8a" opacity="0.8"/>
        <rect x="130" y="7" width="8" height="4" rx="1" fill="#3a5a8a" opacity="0.8"/>
        <rect x="160" y="7" width="8" height="4" rx="1" fill="#3a5a8a" opacity="0.8"/>
        <rect x="190" y="7" width="8" height="4" rx="1" fill="#3a5a8a" opacity="0.8"/>
        <rect x="220" y="7" width="8" height="4" rx="1" fill="#3a5a8a" opacity="0.8"/>
        <rect x="250" y="7" width="8" height="4" rx="1" fill="#3a5a8a" opacity="0.8"/>
        <!-- Oars -->
        <line x1="60" y1="10" x2="20" y2="30" stroke="#5a8abf" stroke-width="1.5" opacity="0.6"/>
        <line x1="100" y1="10" x2="60" y2="32" stroke="#5a8abf" stroke-width="1.5" opacity="0.6"/>
        <line x1="140" y1="10" x2="100" y2="32" stroke="#5a8abf" stroke-width="1.5" opacity="0.6"/>
        <line x1="180" y1="10" x2="140" y2="32" stroke="#5a8abf" stroke-width="1.5" opacity="0.5"/>
        <!-- Other side oars -->
        <line x1="80" y1="9" x2="110" y2="28" stroke="#5a8abf" stroke-width="1.5" opacity="0.6"/>
        <line x1="120" y1="9" x2="150" y2="28" stroke="#5a8abf" stroke-width="1.5" opacity="0.6"/>
        <line x1="160" y1="9" x2="190" y2="28" stroke="#5a8abf" stroke-width="1.5" opacity="0.5"/>
        <line x1="200" y1="9" x2="230" y2="28" stroke="#5a8abf" stroke-width="1.5" opacity="0.5"/>
        <!-- Boat label -->
        <text x="180" y="5" font-family="system-ui" font-size="7"
              fill="#8ab4d4" opacity="0.7" text-anchor="middle">
          HUIT+ COMPÉTITION
        </text>
      </g>

      <!-- Boat 2 — Quatre+ (shorter) -->
      <g transform="translate(140, 338)">
        <path d="M0,6 Q40,-1 180,4 Q220,6 240,9 Q220,12 180,10 Q40,14 0,10 Z"
              fill="#1e3a5a" stroke="#3a6090" stroke-width="0.8" opacity="0.85"/>
        <text x="120" y="3" font-family="system-ui" font-size="6"
              fill="#6a94b4" opacity="0.6" text-anchor="middle">
          QUATRE+ DÉCOUVERTE
        </text>
      </g>

      <!-- Boat 3 — Yolette (wider) -->
      <g transform="translate(160, 354)">
        <path d="M0,8 Q30,2 140,6 Q170,8 180,11 Q170,14 140,12 Q30,16 0,12 Z"
              fill="#192d42" stroke="#2a4a6a" stroke-width="0.8" opacity="0.7"/>
        <text x="90" y="4" font-family="system-ui" font-size="6"
              fill="#5a84a4" opacity="0.5" text-anchor="middle">
          YOLETTE LOISIRS
        </text>
      </g>

      <!-- Water reflections from boats -->
      <ellipse cx="240" cy="360" rx="180" ry="8"
               fill="#2a4a7a" opacity="0.3"/>
      <ellipse cx="220" cy="368" rx="120" ry="5"
               fill="#2a4a7a" opacity="0.15"/>

      <!-- Time display — morning atmosphere -->
      <text x="80" y="80" font-family="'Helvetica Neue', Arial, sans-serif"

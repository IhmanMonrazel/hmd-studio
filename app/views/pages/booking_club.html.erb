      <ellipse cx="400" cy="340" rx="500" ry="80"
               fill="#c8d8e8" opacity="0.04"/>
      <ellipse cx="800" cy="330" rx="400" ry="60"
               fill="#d0dde8" opacity="0.04"/>

      <!-- Water surface -->
      <rect x="0" y="340" width="1200" height="260" fill="#1e3048"/>

      <!-- Water shimmer lines -->
      <line x1="0" y1="360" x2="1200" y2="358"
            stroke="#4a6fa5" stroke-width="0.5" opacity="0.3"/>
      <line x1="0" y1="380" x2="1200" y2="382"
            stroke="#4a6fa5" stroke-width="0.3" opacity="0.2"/>
      <line x1="0" y1="400" x2="1200" y2="398"
            stroke="#4a6fa5" stroke-width="0.3" opacity="0.15"/>
      <line x1="0" y1="420" x2="1200" y2="422"
            stroke="#4a6fa5" stroke-width="0.2" opacity="0.1"/>
      <line x1="0" y1="450" x2="1200" y2="448"
            stroke="#4a6fa5" stroke-width="0.2" opacity="0.08"/>


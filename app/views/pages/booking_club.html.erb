<%# ─── HERO ─────────────────────────────────────────────── %>
<section class="bc-hero">
  <div class="bc-hero__inner">
    <p class="bc-hero__eyebrow">01 &mdash; Web Development</p>
    <h1 class="bc-hero__title">BOOKING CLUB</h1>
    <p class="bc-hero__sub">Full-stack booking system for sports clubs</p>
    <p class="bc-hero__stack">Ruby on Rails 7 &nbsp;&middot;&nbsp; PostgreSQL &nbsp;&middot;&nbsp; Turbo &nbsp;&middot;&nbsp; Stimulus &nbsp;&middot;&nbsp; Stripe &nbsp;&middot;&nbsp; Heroku</p>
    <a class="bc-hero__cta"
       href="https://reservation-club-demo-f00667815306.herokuapp.com/"
       target="_blank"
       rel="noopener noreferrer">LIVE DEMO &rarr;</a>
  </div>
</section>

<%# ─── SCENE ───────────────────────────────────────────── %>
<section class="bc-scene">
  <div class="bc-scene__map">
    <svg class="bc-scene__svg" viewBox="0 0 1200 600"
         xmlns="http://www.w3.org/2000/svg"
         preserveAspectRatio="xMidYMid slice">


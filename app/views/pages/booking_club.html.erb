        <!-- Slot 1 -->
        <rect y="14" width="160" height="28" rx="4"
              fill="#2a4a6a" opacity="0.7"/>
        <rect y="14" width="4" height="28" rx="1" fill="#4dba7f" opacity="0.9"/>
        <text x="12" y="25" font-family="system-ui" font-size="9"
              font-weight="600" fill="#ffffff" opacity="0.9">14h00</text>
        <text x="12" y="36" font-family="system-ui" font-size="7"
              fill="#8ab4d4" opacity="0.7">Huit+ Compétition</text>

        <!-- Slot 2 -->
        <rect y="48" width="160" height="28" rx="4"
              fill="#2a4a6a" opacity="0.6"/>
        <rect y="48" width="4" height="28" rx="1" fill="#4dba7f" opacity="0.8"/>
        <text x="12" y="59" font-family="system-ui" font-size="9"
              font-weight="600" fill="#ffffff" opacity="0.85">14h00</text>
        <text x="12" y="70" font-family="system-ui" font-size="7"
              fill="#8ab4d4" opacity="0.6">Quatre+ Découverte</text>

        <!-- Slot 3 -->
        <rect y="82" width="160" height="28" rx="4"
              fill="#2a4a6a" opacity="0.5"/>
        <rect y="82" width="4" height="28" rx="1" fill="#4dba7f" opacity="0.7"/>
        <text x="12" y="93" font-family="system-ui" font-size="9"
              font-weight="600" fill="#ffffff" opacity="0.8">14h00</text>
        <text x="12" y="104" font-family="system-ui" font-size="7"
              fill="#8ab4d4" opacity="0.55">Yolette Loisirs</text>
      </g>

      <!-- Stripe payment badge -->
      <g transform="translate(80, 280)">
        <rect width="120" height="28" rx="4"
              fill="#1e3048" stroke="#3a5470" stroke-width="0.8"/>
        <text x="12" y="18" font-family="system-ui" font-size="9"
              fill="#8ab4d4" opacity="0.7" letter-spacing="1">
          STRIPE · SÉCURISÉ
        </text>
      </g>

      <!-- Dark overlay right side for card readability -->
      <rect x="700" y="0" width="500" height="600"
            fill="#0d1520" opacity="0.6"/>

      <!-- Overall dark overlay -->
      <rect width="1200" height="600" fill="#000000" opacity="0.25"/>
    </svg>
  </div>

  <!-- Booking card floating right -->
  <div class="bc-scene__card">
    <div class="bc-scene__card-header">
      <span class="bc-scene__badge">DISPONIBLE</span>
      <h3 class="bc-scene__title">Huit+ Compétition</h3>
      <p class="bc-scene__price">30.00 € / heure</p>
    </div>
    <div class="bc-scene__divider"></div>
    <div class="bc-scene__fields">
      <div class="bc-scene__field">
        <span class="bc-scene__label">DATE</span>
        <div class="bc-scene__input">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.5" width="13" height="13">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          26/03/2026
        </div>
      </div>
      <div class="bc-scene__row">
        <div class="bc-scene__field">
          <span class="bc-scene__label">DÉBUT</span>
          <div class="bc-scene__input">06:00</div>
        </div>
        <div class="bc-scene__field">
          <span class="bc-scene__label">FIN</span>
          <div class="bc-scene__input">07:00</div>
        </div>
      </div>
      <p class="bc-scene__avail">
        <span class="bc-scene__avail-dot"></span>
        Tous les créneaux disponibles
      </p>
    </div>
    <div class="bc-scene__divider"></div>
    <div class="bc-scene__total">
      <div class="bc-scene__total-line">
        <span>Tarif</span><span>60.00 €</span>
      </div>
      <div class="bc-scene__total-line bc-scene__total-line--bold">
        <span>Total</span><span>60.00 €</span>
      </div>
    </div>
    <button class="bc-scene__cta">VALIDER LA RÉSERVATION</button>
  </div>
</section>

<%# ─── SHOWCASE ─────────────────────────────────────── %>
<section class="bc-showcase" data-controller="gsap-showcase">
  <div class="bc-showcase__inner">

    <div class="bc-showcase__grid">

      <%# Bloc 1 — Carte ressource (slide depuis gauche) %>
      <div class="bcs-resource" data-gsap-showcase-target="resource">
        <span class="bcs-resource__badge">DISPONIBLE</span>
        <h2 class="bcs-resource__title">Huit+ Compétition</h2>
        <div class="bcs-resource__price">30.00 &euro; / heure</div>
        <div class="bcs-resource__hours">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14">
            <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
          </svg>
          06h &ndash; 21h
        </div>
      </div>

      <%# Bloc 2 — Formulaire réservation (fade in depuis le bas) %>
      <div class="bcs-form" data-gsap-showcase-target="form">
        <div class="bcs-form__row">
          <div class="bcs-form__field bcs-form__field--full">
            <label class="bcs-form__label">DATE</label>
            <div class="bcs-form__input">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14">
                <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
              </svg>
              26/03/2026
            </div>
          </div>
        </div>
        <div class="bcs-form__row">
          <div class="bcs-form__field">
            <label class="bcs-form__label">DÉBUT</label>
            <div class="bcs-form__input">06:00</div>
          </div>
          <div class="bcs-form__field">
            <label class="bcs-form__label">FIN</label>
            <div class="bcs-form__input">07:00</div>
          </div>
        </div>
        <p class="bcs-form__avail">
          <span class="bcs-form__avail-dot"></span>
          Tous les cr&eacute;neaux sont disponibles
        </p>
      </div>

      <%# Bloc 3 — Grille de places (stagger pop avec rebond) %>
      <div class="bcs-seats">
        <div class="bcs-seats__grid">
          <div class="bcs-seat bcs-seat--selected" data-gsap-showcase-target="seat">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16">
              <path d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <% 8.times do %>
            <div class="bcs-seat bcs-seat--free" data-gsap-showcase-target="seat">
              <span class="bcs-seat__plus">+</span>
              <span>Libre</span>
            </div>
          <% end %>
        </div>
        <div class="bcs-seats__counter">
          <button class="bcs-seats__btn">&#8722;</button>
          <span class="bcs-seats__count">1 personne</span>
          <button class="bcs-seats__btn">+</button>
        </div>
      </div>

      <%# Bloc 4 — Total et validation (slide depuis droite) %>
      <div class="bcs-total" data-gsap-showcase-target="total">
        <div class="bcs-total__line">
          <span>Tarif</span>
          <span>60.00 &euro;</span>
        </div>
        <div class="bcs-total__divider"></div>
        <div class="bcs-total__line bcs-total__line--bold">
          <span>Total</span>
          <span>60.00 &euro;</span>
        </div>
        <button class="bcs-total__cta">VALIDER LA R&Eacute;SERVATION</button>
      </div>

    </div>
  </div>
</section>
